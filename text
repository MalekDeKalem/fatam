def convert_nifti_to_vtk(nifti_file, time_index=0):

    # Load 4D nifti with nibabel
    nii = nib.load(nifti_file)

    data = nii.get_fdata()

    print("Original shape:", data.shape)

    # Extract one 3D timeframe
    volume = data[:, :, :, time_index]

    print("3D volume shape:", volume.shape)

    # Remove NaNs/Infs
    volume = np.nan_to_num(volume)

    # Convert numpy -> vtkImageData
    vtk_image = vtk.vtkImageData()

    depthArray = numpy_to_vtk(
        num_array=volume.ravel(order='F'),
        deep=True,
        array_type=vtk.VTK_FLOAT
    )

    vtk_image.SetDimensions(volume.shape)
    vtk_image.GetPointData().SetScalars(depthArray)

    # Marching cubes
    mc = vtk.vtkMarchingCubes()
    mc.SetInputData(vtk_image)

    # choose iso value
    iso = np.mean(volume)

    print("Iso:", iso)

    mc.SetValue(0, iso)
    mc.Update()

    polydata = vtk.vtkPolyData()
    polydata.ShallowCopy(mc.GetOutput())

    print("Points:", polydata.GetNumberOfPoints())

    return polydata
